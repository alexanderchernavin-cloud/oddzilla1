# ─────────────────────────────────────────────────────────────────────────────
# Oddzilla — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.
#
# Each service degrades gracefully when its OPTIONAL vars are absent — see
# the "Optional → effect when absent" table in docs/OPERATIONS.md.
# ─────────────────────────────────────────────────────────────────────────────

# Deployment
NODE_ENV=development
CADDY_HOST=localhost                     # domain for Caddy auto-TLS in prod
LOG_LEVEL=info                           # debug|info|warn|error

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=oddzilla
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=oddzilla
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL consumed by Drizzle (TS) and pgx (Go). Same DB for every service.
DATABASE_URL=postgres://oddzilla:change-me-strong@postgres:5432/oddzilla?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Auth (services/api) ───────────────────────────────────────────────────────
# 32+ byte base64 secrets. Generate: `openssl rand -base64 48`
JWT_SECRET=replace-with-openssl-rand-base64-48
REFRESH_COOKIE_SECRET=replace-with-openssl-rand-base64-48
JWT_ACCESS_TTL_SECONDS=900               # 15 minutes
REFRESH_TTL_DAYS=30

# ── Oddin integration (protocol level, no SDK) ────────────────────────────────
# Used by services/feed-ingester and services/settlement.
ODDIN_ENV=integration                    # integration|production
ODDIN_TOKEN=                             # provided by Oddin; AMQP user + x-access-token
ODDIN_CUSTOMER_ID=                       # GET /users/whoami; drives AMQP vhost
ODDIN_NODE_ID=1
ODDIN_LANG=en                            # used by /v1/descriptions/{lang}/...
# AMQP — integration host shown; for production: mq.oddin.gg
ODDIN_AMQP_HOST=mq.integration.oddin.gg
ODDIN_AMQP_PORT=5672                     # AMQPS over 5672 (Oddin convention; not 5671)
ODDIN_AMQP_TLS=true
# REST — integration host shown; for production: https://api-mq.oddin.gg
ODDIN_REST_BASE_URL=https://api-mq.integration.oddin.gg
# Routing key filter (topic-8-section pattern). '#' = all messages.
ODDIN_AMQP_ROUTING_KEY=#
# Settlement runs its own consumer with its own queue; can narrow the
# binding to settlement-family messages only if Oddin starts spamming us.
SETTLEMENT_AMQP_ROUTING_KEY=#

# ── Wallet / on-chain (services/wallet-watcher + services/api) ────────────────
# HD master key (BIP39 12/24-word phrase). Empty = no HD derivation in API
# (deposit-addresses endpoint will 500 with a clear error).
# Pre-launch: this moves into a dedicated signer container; the API stops
# reading it directly. See Phase 7 exit criteria in docs/PHASES.md.
HD_MASTER_MNEMONIC=
# Tron — mainnet shown; testnet: https://api.shasta.trongrid.io
TRON_RPC_URL=https://api.trongrid.io
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_CONFIRMATIONS=19
# Ethereum — empty = ERC20 scanner disabled. Alchemy/Infura/QuickNode all work.
ETH_RPC_URL=
ETH_USDT_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
ETH_CONFIRMATIONS=12

# ── Service tuning (all optional with sensible defaults) ──────────────────────
# odds-publisher: consumer group + batch
ODDS_PUBLISHER_GROUP=odds-publisher
ODDS_PUBLISHER_BATCH=128
# bet-delay: sweep cadence + drift tolerance (basis points; 500 = 5%)
BET_DELAY_SWEEP_MS=1000
BET_DELAY_DRIFT_BP=500
BET_DELAY_BATCH=100
# settlement: rollback chunk size
SETTLEMENT_ROLLBACK_BATCH=100
# wallet-watcher: poll interval + per-chain block range per tick
WALLET_POLL_MS=5000
TRON_START_BLOCK=0                       # ms timestamp; 0 = bootstrap from now-10min
TRON_MAX_BLOCK_RANGE=50                  # blocks (~150 s window)
ETH_START_BLOCK=0                        # block number; 0 = bootstrap from head-1
ETH_MAX_BLOCK_RANGE=1000

# ── Service ports (exposed inside Docker network; Caddy fronts them in prod) ──
API_PORT=3001
WS_GATEWAY_PORT=3002
WEB_PORT=3000
FEED_INGESTER_HEALTH_PORT=8081
ODDS_PUBLISHER_HEALTH_PORT=8082
SETTLEMENT_HEALTH_PORT=8083
BET_DELAY_HEALTH_PORT=8084
WALLET_WATCHER_HEALTH_PORT=8085

# ── Frontend (apps/web) ───────────────────────────────────────────────────────
# Public URLs used by the browser. On the Hetzner box, set to https://<CADDY_HOST>.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
# Internal URL used by Next.js server components to reach the API over the
# Docker network. In dev set to http://localhost:3001; in Docker set to
# http://api:3001 (Compose DNS resolves the service name).
INTERNAL_API_URL=http://api:3001

# ── CORS (services/api) ───────────────────────────────────────────────────────
# Comma-separated list of origins that can hit the API with credentials.
# Must include the web app's origin.
CORS_ORIGINS=http://localhost:3000
# Optional — set in prod to enable cross-subdomain cookies.
COOKIE_DOMAIN=

# ── Seed / bootstrap accounts (used by `make seed`) ───────────────────────────
SEED_ADMIN_EMAIL=admin@oddzilla.local
SEED_ADMIN_PASSWORD=ChangeMeAdmin123!
SEED_USER_EMAIL=user@oddzilla.local
SEED_USER_PASSWORD=ChangeMeUser123!

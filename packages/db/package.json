    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@oddzilla/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",

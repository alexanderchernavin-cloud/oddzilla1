{
  "name": "@oddzilla/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./enums": "./src/enums.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",

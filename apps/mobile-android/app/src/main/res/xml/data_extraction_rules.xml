<?xml version="1.0" encoding="utf-8"?>
<!-- Disable cloud + device-transfer backup of app data. The session
     cookies stored in DataStore are sensitive and must not be replicated
     across devices via auto backup. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>

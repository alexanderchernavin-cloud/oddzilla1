# Copy to keystore.properties (gitignored) once you've generated the
# release keystore (see scripts/generate-keystore.ps1).
#
# These values feed app/build.gradle.kts release signing config. The
# keystore file itself lives outside the repo (e.g. ~/keys/oddzilla.jks)
# so it never gets committed.

storeFile=C:/Users/<you>/keys/oddzilla.jks
storePassword=<keystore-password>
keyAlias=oddzilla
keyPassword=<key-password>

# Caddy config — multi-host: public frontend + admin backoffice.
#
# For local dev, set `FRONTEND_HOST=localhost` and `ADMIN_HOST=admin.localhost`.
# For production on Hetzner, set both to real hostnames (e.g.
# `s.oddzilla.cc` and `sadmin.oddzilla.cc`). Caddy will auto-request
# Let's Encrypt certificates on first boot.

{
	admin off
	email {$ACME_EMAIL}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

(web_csp) {
	# CSP applied only to responses from web:3000 (Next.js HTML). /api/* has
	# its own strict default-src 'none' CSP from @fastify/helmet.
	# Backticks preserve semicolons/quotes inside the value.
	header Content-Security-Policy `default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests`
}

# Static team logos written to the `team-logos` volume by the api
# container's resolve-logos / apply-logo-seed scripts. Served with a
# year-long cache because the file path is keyed on competitor.id +
# content hash — overwrites use a different filename, so the URL itself
# is the cache buster.
(team_logos) {
	handle_path /team-logos/* {
		root * /srv/team-logos
		file_server {
			hide .* _*
		}
		header Cache-Control "public, max-age=31536000, immutable"
		header Access-Control-Allow-Origin "*"
	}
}

# ── Public frontend ──────────────────────────────────────────────────────────
{$FRONTEND_HOST} {
	encode zstd gzip
	import security_headers
	import team_logos

	handle_path /api/* {
		reverse_proxy api:3001
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	handle /ws* {
		reverse_proxy ws-gateway:3002
	}

	handle {
		import web_csp
		reverse_proxy web:3000
	}
}

# ── Admin backoffice ─────────────────────────────────────────────────────────
# Same Next.js container, root redirects to /admin so operators never land on
# marketing pages. Auth + role checks inside /admin routes remain the real
# access control.
{$ADMIN_HOST} {
	encode zstd gzip
	import security_headers
	import team_logos

	redir / /admin 302

	handle_path /api/* {
		reverse_proxy api:3001
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	handle /ws* {
		reverse_proxy ws-gateway:3002
	}

	handle {
		import web_csp
		reverse_proxy web:3000
	}
}

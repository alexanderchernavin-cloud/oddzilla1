# Caddy config — multi-host: public frontend + admin backoffice.
#
# For local dev, set `FRONTEND_HOST=localhost` and `ADMIN_HOST=admin.localhost`.
# For production on Hetzner, set both to real hostnames (e.g.
# `s.oddzilla.cc` and `sadmin.oddzilla.cc`). Caddy will auto-request
# Let's Encrypt certificates on first boot.

{
	admin off
	email {$ACME_EMAIL}
	# Edge timeouts shed slowloris-style holders so a few thousand
	# half-open sockets don't exhaust ws-gateway / api file
	# descriptors. Read budget is split between header (5s) and body
	# (30s) — enough for legitimate /admin uploads, tight enough that
	# stalled clients drop. WebSocket upgrades inherit `idle` because
	# the upgraded connection no longer counts as an HTTP read.
	servers {
		timeouts {
			read_header 5s
			read_body   30s
			write       30s
			idle        120s
		}
		max_header_size 16KB
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# Note: Content-Security-Policy is emitted by the Next.js middleware so
# it can mint a per-request nonce and tag the inline theme-boot script.
# Caddy intentionally does NOT set CSP for the web origin; the API origin
# uses @fastify/helmet's strict default-src 'none' policy on /api/*.

# ── Public frontend ──────────────────────────────────────────────────────────
{$FRONTEND_HOST} {
	encode zstd gzip
	import security_headers

	handle_path /api/* {
		# Cap request bodies at the edge — Fastify's per-route default is
		# 1 MiB but slow uploaders still tie up api memory while the body
		# streams in. Matches the largest legitimate admin payload (the
		# 500-entry bulk-logos PUT at ~2 KiB each).
		request_body {
			max_size 1MB
		}
		reverse_proxy api:3001 {
			# Overwrite (not append) X-Forwarded-For so an attacker can't
			# spoof their inbound IP. {remote_host} is the actual
			# connecting client; combined with `trustProxy: 1` on the
			# Fastify side this pins request.ip to the real client.
			header_up X-Forwarded-For {remote_host}
		}
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	handle /ws* {
		reverse_proxy ws-gateway:3002
	}

	handle {
		reverse_proxy web:3000
	}
}

# ── Admin backoffice ─────────────────────────────────────────────────────────
# Same Next.js container, root redirects to /admin so operators never land on
# marketing pages. Auth + role checks inside /admin routes remain the real
# access control.
{$ADMIN_HOST} {
	encode zstd gzip
	import security_headers

	redir / /admin 302

	handle_path /api/* {
		# Cap request bodies at the edge — Fastify's per-route default is
		# 1 MiB but slow uploaders still tie up api memory while the body
		# streams in. Matches the largest legitimate admin payload (the
		# 500-entry bulk-logos PUT at ~2 KiB each).
		request_body {
			max_size 1MB
		}
		reverse_proxy api:3001 {
			# Overwrite (not append) X-Forwarded-For so an attacker can't
			# spoof their inbound IP. {remote_host} is the actual
			# connecting client; combined with `trustProxy: 1` on the
			# Fastify side this pins request.ip to the real client.
			header_up X-Forwarded-For {remote_host}
		}
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	handle /ws* {
		reverse_proxy ws-gateway:3002
	}

	handle {
		reverse_proxy web:3000
	}
}

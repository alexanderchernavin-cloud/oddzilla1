{
  "name": "oddzilla",
  "private": true,
  "version": "0.0.0",
  "description": "Oddzilla B2C esports sportsbook — Oddin.gg protocol-level integration.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @oddzilla/db db:generate",
    "db:migrate": "pnpm --filter @oddzilla/db db:migrate",
    "db:seed": "pnpm --filter @oddzilla/db db:seed",
    "db:studio": "pnpm --filter @oddzilla/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
